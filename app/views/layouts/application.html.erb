<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} ・ 綴り" : "綴り — Tsuzuri" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app">
      <%= render "layouts/rail" %>

      <main class="main">
        <% if notice.present? %><p class="flash notice"><%= notice %></p><% end %>
        <% if alert.present? %><p class="flash alert"><%= alert %></p><% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
