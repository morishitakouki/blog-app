<% content_for :title, "アカウント設定" %>

<div class="col-head">
  <%= link_to settings_path, class: "back-link", aria: { label: "戻る" } do %>
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
  <% end %>
  <h1>アカウント設定</h1>
</div>

<div class="form-card">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <%= f.label :email, "メールアドレス" %>
      <%= f.email_field :email, autocomplete: "email" %>
    </div>

    <div class="field">
      <%= f.label :password, "新しいパスワード" %>
      <%= f.password_field :password, autocomplete: "new-password" %>
      <p class="hint">変更しない場合は空欄のまま<% if @minimum_password_length %>（<%= @minimum_password_length %>文字以上）<% end %></p>
    </div>

    <div class="field">
      <%= f.label :password_confirmation, "新しいパスワード（確認）" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
    </div>

    <div class="field">
      <%= f.label :current_password, "現在のパスワード" %>
      <%= f.password_field :current_password, autocomplete: "current-password" %>
      <p class="hint">変更を確定するために現在のパスワードが必要です。</p>
    </div>

    <div class="compose-foot">
      <%= f.submit "更新する", class: "btn" %>
    </div>
  <% end %>

  <hr style="border:0; border-top:1px solid var(--line-soft); margin:1.6rem 0;">

  <p class="hint" style="margin-bottom:.6rem;">アカウントを削除すると、投稿もすべて削除されます。</p>
  <%= button_to "アカウントを削除", registration_path(resource_name), method: :delete,
        class: "btn danger",
        form: { data: { turbo_confirm: "本当にアカウントを削除しますか？" } } %>
</div>
