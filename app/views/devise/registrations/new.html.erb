<% content_for :title, "新規登録" %>

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="brand-mark">綴</span>
      <h2 style="text-align:center; margin-top:.4rem;">綴りをはじめる</h2>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="field">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, autocomplete: "new-password" %>
        <% if @minimum_password_length %>
          <p class="hint"><%= @minimum_password_length %>文字以上</p>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, "パスワード（確認）" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="actions">
        <%= f.submit "登録する" %>
      </div>
    <% end %>

    <p class="hint" style="text-align:center; margin-top:1rem;">登録後、設定画面で表示名や@ユーザー名を変更できます。</p>
    <%= render "devise/shared/links" %>
  </div>
</div>
