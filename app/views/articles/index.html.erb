<% content_for :title, "ホーム" %>

<div class="col-head">
  <div>
    <h1>ホーム</h1>
    <p class="sub">みんなのタイムライン</p>
  </div>
</div>

<div id="articles">
  <% if @articles.any? %>
    <% @articles.each do |article| %>
      <%= render article %>
    <% end %>
  <% else %>
    <div class="empty">
      <div class="quill">🪶</div>
      <h3>まだ記事がありません</h3>
      <p>最初の一篇を綴ってみましょう。</p>
      <% if user_signed_in? %>
        <%= link_to "記事を書く", new_article_path, class: "btn", style: "margin-top:.6rem" %>
      <% else %>
        <%= link_to "新規登録してはじめる", new_user_registration_path, class: "btn", style: "margin-top:.6rem" %>
      <% end %>
    </div>
  <% end %>
</div>
